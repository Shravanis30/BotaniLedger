# Server
NODE_ENV=production
PORT=5000
API_BASE_URL=https://api.botanyledger.com

# Database
MONGODB_URI=mongodb://localhost:27017/botanyledger
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# IPFS / Pinata
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_secret
PINATA_JWT=your_pinata_jwt
PINATA_GATEWAY=https://gateway.pinata.cloud
IPFS_FALLBACK_1=https://cloudflare-ipfs.com/ipfs
IPFS_FALLBACK_2=https://dweb.link/ipfs
IPFS_FALLBACK_3=https://ipfs.io/ipfs

# Hyperledger Fabric
FABRIC_CHANNEL=botanyledger-channel
FABRIC_CHAINCODE=botanyledger
FABRIC_MSP_FARMER=FarmerOrgMSP
FABRIC_MSP_LAB=LabOrgMSP
FABRIC_MSP_MANUFACTURER=ManufacturerOrgMSP
FABRIC_ORDERER_URL=grpcs://localhost:7050
FABRIC_PEER_FARMER=grpcs://localhost:7051
FABRIC_PEER_LAB=grpcs://localhost:8051
FABRIC_PEER_MANUFACTURER=grpcs://localhost:9051

# AI Service
AI_SERVICE_URL=http://localhost:8000
CNN_CONFIDENCE_THRESHOLD=85
SIMILARITY_GREEN_THRESHOLD=90
SIMILARITY_YELLOW_THRESHOLD=70

# Notifications
FIREBASE_PROJECT_ID=botanyledger
FIREBASE_PRIVATE_KEY=your_firebase_key
FIREBASE_CLIENT_EMAIL=firebase@botanyledger.iam.gserviceaccount.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@botanyledger.com
SMTP_PASS=your_smtp_password

# QR Code
QR_BASE_URL=https://botanyledger.com/verify
QR_SECRET=your_qr_signing_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Monitoring
PROMETHEUS_PORT=9090
SENTRY_DSN=your_sentry_dsn
